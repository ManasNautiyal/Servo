# Python virtual environments
backend/venv/
venv/
.venv/
env/

# Python cache & build files
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.cache/

# Local databases (SQLite)
backend/servo.db
*.db
*.db-journal
*.db-shm
*.db-wal

# Secrets & Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local

# Frontend build & packages (also covered by frontend's local .gitignore)
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# User visual assets/uploads (resumes, avatar images uploaded locally during testing)
backend/static/uploads/*
!backend/static/uploads/.gitkeep

# Operating system & Editor configuration folders
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
*.swp
