# Servo Backend Environment Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/servo
JWT_SECRET=supersecretjwtsecretkeychangeinproduction123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Supabase Storage Configuration (for profile pic / resumes / portfolio images)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=servo-storage

# Gemini API Configuration (for AI-powered suggestions / recommendation / description generation)
GEMINI_API_KEY=your-gemini-api-key
