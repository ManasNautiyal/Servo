# Servo Backend Environment Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/servo
JWT_SECRET=supersecretjwtsecretkeychangeinproduction123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Supabase Storage Configuration (for profile pic / resumes / portfolio images)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=servo-storage

# Gemini API Configuration (for AI-powered suggestions / recommendation / description generation)
GEMINI_API_KEY=your-gemini-api-key

# SMTP Email Configuration (Optional: for sending real registration OTPs)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER=your-email@gmail.com

# Resend Email API Configuration (Optional: HTTP-based bypass for blocked SMTP ports)
RESEND_API_KEY=your-resend-api-key
